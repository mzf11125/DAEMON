# Snyk policy — https://docs.snyk.io/manage-risk/policies/the-.snyk-file
version: v1.25.0
ignore: {}
patch: {}
exclude:
  code:
    - tests/**
    - "**/*.test.ts"
    - "**/*.test.tsx"
