# Staging pilot — copy to .env.staging (gitignored). Never commit secrets.
# Phase 0 exit gates: all *_URL values must be non-localhost (https://).
# See docs/operations/staging-vm-compose-v1.md and docs/operations/phase0-exit-gates-v1.md

# --- Public service URLs (required for prove-staging-smoke) ---
PLATFORM_API_URL=https://staging-api.example.com
ONTOLOGY_SERVICE_URL=https://staging-api.example.com/ontology
RULES_ENGINE_URL=https://staging-api.example.com/rules
CASE_SERVICE_URL=https://staging-api.example.com/cases
INGESTION_SERVICE_URL=https://staging-api.example.com/ingestion

# Console (Vercel or K8s ingress)
NEXT_PUBLIC_PLATFORM_API_URL=https://staging-api.example.com
NEXT_PUBLIC_ONTOLOGY_URL=https://staging-api.example.com/ontology

# --- Auth (staging Supabase project) ---
OIDC_ISSUER=https://YOUR_PROJECT.supabase.co/auth/v1
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=  # seed/migrate only — not runtime Go services
# SUPABASE_JWT_SECRET=

# Go services on staging must set:
OIDC_REQUIRED=true

# --- Data plane (managed or staging VM) ---
DATABASE_URL=postgresql://daemon_runtime:REDACTED@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require
CLICKHOUSE_URL=http://clickhouse.staging.internal:8123
NEO4J_URI=bolt://neo4j.staging.internal:7687

# --- Agent / AIP ---
AGENT_BRIDGE_URL=https://staging-agent.example.com
# LANGCHAIN_API_KEY=  # P1.12 — staging/prod agent paths

# --- Proof scripts (optional) ---
# PHASE0_STRICT=1  # fail prove-staging-smoke if URLs still localhost
