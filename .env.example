# Postgres — Supabase local (DAEMON ports in supabase/config.toml: API 54331, DB 54332)
DATABASE_URL=postgresql://daemon_runtime:daemon_runtime_local@127.0.0.1:54332/postgres?sslmode=disable
# Migrations + seed only (superuser — never use as Go service DATABASE_URL)
SEED_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54332/postgres?sslmode=disable

# Legacy Docker Postgres (profile legacy-keycloak)
# DATABASE_URL=postgres://daemon:daemon@localhost:5432/daemon?sslmode=disable

# ClickHouse (local docker compose)
CLICKHOUSE_DSN=clickhouse://daemon:daemon@localhost:9000/daemon

# ClickHouse Cloud management API (optional; copy Key ID/Secret from console or clickhouse-api-key-*.txt)
# Used for api.clickhouse.cloud OpenAPI — not the same as remote MCP OAuth at mcp.clickhouse.cloud
CLICKHOUSE_CLOUD_KEY_ID=
CLICKHOUSE_CLOUD_KEY_SECRET=
CLICKHOUSE_CLOUD_API_URL=https://api.clickhouse.cloud/v1

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=daemonneo4j

# MinIO (attachment plane — local docker compose port 9002)
MINIO_ENDPOINT=127.0.0.1:9002
MINIO_ACCESS_KEY=daemon
MINIO_SECRET_KEY=daemonsecret
MINIO_BUCKET=daemon-attachments
MINIO_USE_SSL=false

# Ontology manifests (repo-relative)
ONTOLOGY_ROOT=./ontology/v2

# Service ports
PLATFORM_API_ADDR=:8080
ONTOLOGY_SERVICE_ADDR=:8081
INGESTION_SERVICE_ADDR=:8082
RULES_ENGINE_ADDR=:8083
CASE_SERVICE_ADDR=:8084

# Public URLs (console-web)
NEXT_PUBLIC_PLATFORM_API_URL=http://localhost:8080
NEXT_PUBLIC_ONTOLOGY_SERVICE_URL=http://localhost:8081
NEXT_PUBLIC_CASE_SERVICE_URL=http://localhost:8084
NEXT_PUBLIC_RULES_ENGINE_URL=http://localhost:8083
NEXT_PUBLIC_INGESTION_SERVICE_URL=http://localhost:8082
NEXT_PUBLIC_TENANT_ID=tenant-demo
# Supabase Auth (local CLI — console + Go services)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from supabase status>
SUPABASE_SERVICE_ROLE_KEY=<server only — seed script>
SUPABASE_JWT_SECRET=<from supabase status>
SUPABASE_DEMO_USER_ID=<UUID from scripts/supabase-seed-auth.sh>

OIDC_REQUIRED=true
OIDC_ISSUER=http://127.0.0.1:54331/auth/v1
OIDC_AUDIENCE=authenticated

# AIP eval / integration harness (console stays OIDC_REQUIRED=true):
# OIDC_REQUIRED=false

# Legacy Keycloak (docker compose --profile legacy-keycloak)
# NEXT_PUBLIC_OIDC_ISSUER=http://localhost:8180/realms/daemon-demo
# NEXT_PUBLIC_OIDC_CLIENT_ID=console-web
# OIDC_REQUIRED=false
# OIDC_ISSUER=http://localhost:8180/realms/daemon-demo
# OIDC_AUDIENCE=console-web

# AIP / MCP
ONTOLOGY_SERVICE_URL=http://localhost:8081
PLATFORM_API_URL=http://localhost:8080
CASE_SERVICE_URL=http://localhost:8084
TENANT_ID=tenant-demo
MCP_TOOL_SCHEMA_VERSION=0.2.0
MCP_SSE_PORT=8090
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LLM gateway (Phase 2)
LLM_GATEWAY_PORT=8092
LLM_GATEWAY_URL=http://localhost:8092
LLM_GATEWAY_ENABLED=false
# Eval / agent (Merge Phase 2 — HTTP bridge to Go; full upstream engine needs Postgres+Redis)
AGENT_DAEMON_BRIDGE=true
AGENT_PORT=3001
# Eval / agent
EVAL_DETERMINISTIC=true
AGENT_MAX_STEPS=3
PROMPT_VERSION=v1
AIP_MAX_PROMPT_CHARS=12000
AIP_MAX_OUTPUT_TOKENS=1024
# LangSmith (required in staging per docs/aip/langsmith-observability-v1.md)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=daemon-aip-dev

# Optional webhook for action side effects
ACTION_WEBHOOK_URL=

# Optional ontology vertical pack (default: core only)
ONTOLOGY_PACK=

# Market intelligence (pipelines/market-intel — Tavily + L3 pgvector)
# Docs: docs/operations/market-intelligence-v1.md
# Apply migration: infra/migrations/postgres/007_market_intel_pgvector.sql (requires pgvector extension)
TAVILY_API_KEY=
# LLM: reuses AIP OpenRouter (preferred) or direct OpenAI — see OPENROUTER_* above
# OPENAI_API_KEY=
MARKET_INTEL_MODEL=openrouter:openai/gpt-4o-mini
# Optional OpenRouter attribution headers (leaderboard / app attribution)
# OPENROUTER_SITE_URL=https://daemon-system.local
# OPENROUTER_APP_NAME=Daemon Market Intel
# Optional L2c Shodan Trends (auto in market-map when set)
SHODAN_API_KEY=
# L3 embeddings — must match migration vector(3072); OpenRouter uses openai/ prefix automatically
MARKET_INTEL_EMBEDDING_MODEL=text-embedding-3-large
MARKET_INTEL_EMBEDDING_DIMS=3072
# GEO/AIO/E-E-A-T enrichment (default on; CLI: --no-ai-visibility)
MARKET_INTEL_AI_VISIBILITY=true
# Optional tuning
# MARKET_INTEL_ARTIFACTS=./artifacts/market-intel
# MARKET_INTEL_MAX_SEARCH_RESULTS=8
# MARKET_INTEL_SEARCH_TOKEN_LIMIT=12000
# MARKET_INTEL_TAVILY_TIMEOUT=60
# Prove: make market-intel-install && make prove-market-intel-security
# Full stack: make prove-market-intel prove-market-intel-rag (needs DATABASE_URL + keys above)
