{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "DAEMON SDK",
  "description": "Semantic control plane — ingest, ontology, governed read/write, and action runtime.",
  "colors": {
    "primary": "#0F766E",
    "light": "#14B8A6",
    "dark": "#115E59"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "guides/engineering-docs-index",
              "guides/using-mintlify-mcp"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "architecture/overview",
              "architecture/end-to-end",
              "architecture/bounded-contexts",
              "architecture/ontology-system",
              "architecture/read-write-loops",
              "architecture/language-engine",
              "architecture/sequence-flows"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "operations/go-live",
              "operations/testing",
              "operations/deployment",
              "operations/observability-runbook",
              "operations/observability",
              "operations/security-governance"
            ]
          },
          {
            "group": "Platform maps",
            "pages": [
              "platform/data-integration-map",
              "platform/data-connection-map",
              "platform/data-ops-lifecycle",
              "platform/platform-decision-map",
              "platform/enterprise-platform-map",
              "platform/product-parity"
            ]
          },
          {
            "group": "Develop",
            "pages": ["guides/sdk"]
          },
          {
            "group": "Data & semantics",
            "pages": [
              "data/lakehouse",
              "data/neo4j-graph",
              "data/connectors-catalog",
              "semantics/governance-alignment",
              "semantics/competency-questions"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/daemon-blockint-tech/DAEMON",
          "icon": "github"
        },
        {
          "anchor": "Source docs (Markdown)",
          "href": "https://github.com/daemon-blockint-tech/DAEMON/tree/main/docs",
          "icon": "book"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Repository",
        "href": "https://github.com/daemon-blockint-tech/DAEMON"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/daemon-blockint-tech/DAEMON"
    }
  }
}
