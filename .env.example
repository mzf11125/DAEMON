ONTOLOGY_SERVICE_URL=http://localhost:8081
PLATFORM_API_URL=http://localhost:8080
CASE_SERVICE_URL=http://localhost:8084
TENANT_ID=tenant-demo
MCP_TOOL_SCHEMA_VERSION=0.2.0
MCP_SSE_PORT=8090
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LLM gateway (Phase 2)
LLM_GATEWAY_PORT=8092
LLM_GATEWAY_URL=http://localhost:8092
LLM_GATEWAY_ENABLED=false
# Eval / agent (Merge Phase 2 — HTTP bridge to Go; full upstream engine needs Postgres+Redis)
