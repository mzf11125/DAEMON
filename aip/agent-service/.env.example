# =============================================================================
# apps/agent-service — Agent Service
# Copy ke apps/agent-service/.env lalu isi nilainya
# =============================================================================

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=daemon
DB_PASSWORD=changeme
DB_NAME=daemon

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Ontology schema directory (relatif dari apps/agent-service/)
SCHEMA_DIR=../../schemas

# Tenant default
TENANT_ID=default

# Port (default: 3001)
# AGENT_PORT=3001

# Temperature (default: 0 — deterministik)
# AGENT_TEMPERATURE=0

# =============================================================================
# Model Config — format: "provider:model-name"
# =============================================================================
#
# Provider yang didukung out-of-the-box (OpenAI-compatible, tidak butuh package tambahan):
#   openai       → openai:gpt-4o | openai:gpt-4o-mini | openai:o3
#   openrouter   → openrouter:anthropic/claude-sonnet-4-6 | openrouter:google/gemini-2.0-flash
#   ollama       → ollama:llama3.3 | ollama:qwen3
#   lmstudio     → lmstudio:any-model-name
#   groq         → groq:llama-3.3-70b-versatile | groq:mixtral-8x7b-32768
#   together     → together:meta-llama/Llama-3.3-70B-Instruct-Turbo
#   mistral      → mistral:mistral-large-latest
#   custom       → custom:any-model  (wajib set CUSTOM_BASE_URL)
#
# Provider yang butuh package tambahan:
#   anthropic    → install: pnpm add @langchain/anthropic --filter @daemon/agent-service
#   google-genai → install: pnpm add @langchain/google-genai --filter @daemon/agent-service
#   (atau akses keduanya via openrouter tanpa install package tambahan)

AGENT_MODEL=openrouter:minimax/minimax-m2.7

# =============================================================================
# API Keys — isi sesuai provider yang dipakai di AGENT_MODEL
# =============================================================================

# OpenAI (provider: openai)
OPENAI_API_KEY=

# OpenRouter — satu key untuk semua model (provider: openrouter)
OPENROUTER_API_KEY=
# OPENROUTER_SITE_URL=https://your-app.com
# OPENROUTER_APP_NAME=Daemon System Ontology

# Groq (provider: groq) — fast inference
GROQ_API_KEY=

# Together.ai (provider: together)
TOGETHER_API_KEY=

# Mistral (provider: mistral)
MISTRAL_API_KEY=

# Custom provider (provider: custom) — wajib
# CUSTOM_API_KEY=
# CUSTOM_BASE_URL=http://localhost:8080/v1

# =============================================================================
# Base URL Override — opsional, hanya jika ingin override default endpoint
# =============================================================================

# Override OpenAI endpoint (contoh: Azure OpenAI, proxy, atau self-hosted)
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/gpt-4o

# Override OpenRouter endpoint
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama local (default: http://localhost:11434/v1)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# LM Studio local (default: http://localhost:1234/v1)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Groq (default: https://api.groq.com/openai/v1)
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Together.ai (default: https://api.together.xyz/v1)
# TOGETHER_BASE_URL=https://api.together.xyz/v1

# Mistral (default: https://api.mistral.ai/v1)
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# =============================================================================
# LangSmith — opsional, untuk tracing & debugging agent
# =============================================================================
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=daemon-agent-service
# LANGCHAIN_TRACING_V2=true

# =============================================================================
# Client Monitoring Agent — optional scheduled monitoring loop
# =============================================================================
MONITORING_ENABLED=false
MONITORING_INTERVAL_MS=300000
CONTROL_PLANE_URL=http://localhost:4000
CONTROL_PLANE_SECRET=change-me
