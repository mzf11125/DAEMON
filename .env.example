# L3 embeddings — must match migration vector(3072); OpenRouter uses openai/ prefix automatically
MARKET_INTEL_EMBEDDING_MODEL=text-embedding-3-large
MARKET_INTEL_EMBEDDING_DIMS=3072
# GEO/AIO/E-E-A-T enrichment (default on; CLI: --no-ai-visibility)
MARKET_INTEL_AI_VISIBILITY=true
# Optional tuning
# MARKET_INTEL_ARTIFACTS=./artifacts/market-intel
# MARKET_INTEL_MAX_SEARCH_RESULTS=8
# MARKET_INTEL_SEARCH_TOKEN_LIMIT=12000
# MARKET_INTEL_TAVILY_TIMEOUT=60
# Prove: make market-intel-install && make prove-market-intel-security
# Full stack: make prove-market-intel prove-market-intel-rag (needs DATABASE_URL + keys above)
