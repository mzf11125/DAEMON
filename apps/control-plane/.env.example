# Control Plane — DB terpisah dari client tenant DB
DB_HOST=localhost
DB_PORT=5432
DB_USER=daemon
DB_PASSWORD=daemon_control
DB_NAME=daemon_control

# Port (default: 4000)
PORT=4000

# Internal secret — harus kuat di production
INTERNAL_SECRET=change-me-in-production

# Internal operator agent
INTERNAL_AGENT_MODEL=openrouter:minimax/minimax-m2.7
INTERNAL_AGENT_TEMPERATURE=0.2
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
