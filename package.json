{
  "name": "daemon-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Daemon ontology platform monorepo",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "preinstall": "node check-pnpm-version.js",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "dev:gateway": "pnpm exec turbo run build --filter=@daemon/api-gateway^... && DAEMON_API_KEY=daemon-dev-key DAEMON_INGEST_SKIP_UPSTREAM=1 DAEMON_POLICY_SKIP_UPSTREAM=1 pnpm --filter @daemon/api-gateway dev",
    "dev:up": "pnpm run build --filter @daemon/cli && pnpm exec daemon-cli dev up",
    "ontology:port-v3": "tsx scripts/ontology-v3-port.ts",
    "ontology:compile": "pnpm --filter @daemon/ontology-language build && tsx scripts/compile-schemas.ts",
    "daemon-cli": "pnpm --filter @daemon/cli",
    "control-plane": "pnpm --filter @daemon/control-plane",
    "prepare": "husky",
    "check:architecture": "node scripts/check-context-boundaries.mjs",
    "check:route-auth": "node scripts/check-route-auth.mjs",
    "check:tenancy-config": "node scripts/check-tenancy-config.mjs",
    "check:ontology-pack": "node scripts/validate-ontology-pack.mjs",
    "check:sources": "node scripts/validate-sources.mjs",
    "check:governance-policies": "node scripts/check-governance-policies.mjs",
    "check:openapi-gateway-parity": "node scripts/check-openapi-gateway-parity.mjs",
    "check:parity-matrix": "node scripts/check-parity-matrix.mjs",
    "staging:smoke": "node scripts/staging-smoke.mjs",
    "codegen:pack": "node scripts/generate-pack-sdk.mjs",
    "codegen:check": "node scripts/codegen-check.mjs",
    "db:migrate": "pnpm run build --filter @daemon/data-platform && DAEMON_POSTGRES_URL=${DAEMON_POSTGRES_URL:-postgresql://daemon:daemon@127.0.0.1:5432/daemon} node --import tsx data-platform/migrations/run-migrations.ts",
    "spec:check": "node scripts/spec-check.mjs && node scripts/check-openapi-gateway-parity.mjs && node scripts/codegen-check.mjs",
    "spec:manifest": "node scripts/spec-check.mjs --manifest",
    "release:check": "pnpm run build && cd packages/platform-types && npm pack --dry-run && cd ../sdk && npm pack --dry-run && cd ../cli && npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "multer": "^2.1.1",
      "glob@>=10.2.0 <11": "^10.5.0",
      "tmp": "^0.2.7",
      "picomatch": "^4.0.4",
      "qs": "^6.15.2",
      "ajv@>=8.0.0": "^8.18.0",
      "webpack": "^5.104.1",
      "file-type": "^21.3.2",
      "uuid": ">=14.0.0"
    }
  },
  "devDependencies": {
    "@daemon/cli": "workspace:*",
    "@daemon/api-gateway": "workspace:*",
    "@daemon/context-ports": "workspace:*",
    "@daemon/ontology-query": "workspace:*",
    "@daemon/ontology": "workspace:*",
    "@daemon/platform-types": "workspace:*",
    "@daemon/read-write-loops": "workspace:*",
    "@daemon/data-platform": "workspace:*",
    "@daemon/ontology-language": "workspace:*",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "reflect-metadata": "^0.2.2",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.2",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
