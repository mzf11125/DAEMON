ONTOLOGY_PACK=

# Market intelligence (pipelines/market-intel — Tavily + L3 pgvector)
# Docs: docs/operations/market-intelligence-v1.md
# Apply migration: infra/migrations/postgres/007_market_intel_pgvector.sql (requires pgvector extension)
TAVILY_API_KEY=
# LLM: reuses AIP OpenRouter (preferred) or direct OpenAI — see OPENROUTER_* above
# OPENAI_API_KEY=
MARKET_INTEL_MODEL=openrouter:openai/gpt-4o-mini
